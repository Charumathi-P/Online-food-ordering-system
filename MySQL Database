CREATE TABLE users(
id INT PRIMARY KEY AUTO_INCREMENT,
name VARCHAR(50),
email VARCHAR(100),
password VARCHAR(50)
);

CREATE TABLE food(
id INT PRIMARY KEY AUTO_INCREMENT,
name VARCHAR(100),
price DOUBLE,
category VARCHAR(50)
);

CREATE TABLE cart(
id INT PRIMARY KEY AUTO_INCREMENT,
user_id INT,
food_id INT,
quantity INT
);

CREATE TABLE orders(
id INT PRIMARY KEY AUTO_INCREMENT,
user_id INT,
total_amount DOUBLE,
status VARCHAR(30)
);
